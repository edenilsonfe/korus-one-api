# App
APP_NAME=Korus Fono API
DEBUG=true
API_V1_PREFIX=/api/v1
# Origens permitidas em produção (DEBUG=false). Em dev, localhost:* é aceito via regex.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:4173,http://127.0.0.1:3000,http://127.0.0.1:5173,http://127.0.0.1:4173

# Database
DATABASE_URL=postgresql+asyncpg://korus:korus@localhost:5433/korus_one

# JWT
# Obrigatório com DEBUG=false: defina um segredo forte (>=32 caracteres), nunca o valor abaixo.
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH_RATE_LIMIT_FAIL_CLOSED=true
# Hops confiáveis a ignorar da direita em X-Forwarded-For ao obter o IP do cliente
# (rate-limit de auth, remote_ip de billing). 1 = um proxy na frente (Railway/CF).
# Não use o hop mais à esquerda às cegas — o cliente pode forjar hops.
TRUSTED_PROXY_COUNT=1

# Redis (arq worker)
REDIS_URL=redis://localhost:6380

# Transactional email (Resend)
RESEND_API_KEY=
EMAIL_FROM=Korus Fono <noreply@seudominio.com>
EMAIL_SENDING_ENABLED=false
PASSWORD_TOKEN_EXPIRE_MINUTES=60
PASSWORD_RESET_COOLDOWN_SECONDS=60

# MinIO (dev) / AWS S3 (prod)
# Dev:
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=korus-attachments
S3_REGION=us-east-1
# Tamanho máximo de upload de anexos do prontuário, em bytes (padrão: 25 MB)
MAX_UPLOAD_BYTES=26214400

# OpenCode Zen (LLM — API compatível com OpenAI)
# Chave em https://opencode.ai/auth
OPENCODE_API_KEY=
OPENCODE_BASE_URL=https://opencode.ai/zen/v1
OPENCODE_MODEL=deepseek-v4-flash

# WhatsApp / Evolution API
WHATSAPP_PROVIDER=evolution
WHATSAPP_CREDENTIAL_ENCRYPTION_KEY=
APP_PUBLIC_URL=
EVOLUTION_API_BASE_URL=http://localhost:8080
EVOLUTION_GLOBAL_API_KEY=
# Usado como Bearer no webhook da instância e como segredo HMAC (X-Webhook-Signature).
# Na Evolution, configure o mesmo valor em WEBHOOK_GLOBAL_HMAC_SECRET quando usar HMAC global.
EVOLUTION_WEBHOOK_SECRET=
CLINIC_TIMEZONE=America/Sao_Paulo
# Nota: o cron do worker ARQ está fixo em :00/:15/:30/:45; este valor é documentacional.
WHATSAPP_SCHEDULER_INTERVAL_SECONDS=900
WHATSAPP_REMINDER_WINDOW_HOURS=24
WHATSAPP_REMINDER_TOLERANCE_MINUTES=15
# Só ative se estiver rodando `uv run arq worker.WorkerSettings`. Sem worker, mensagens
# ficam presas no Redis. Default (ausente/false) = envio inline na request da agenda.
# WHATSAPP_USE_ARQ_DISPATCH=false

# Billing / Asaas
BILLING_PROVIDER=stub
ASAAS_API_KEY=
ASAAS_API_BASE_URL=https://sandbox.asaas.com/api/v3
# Obrigatório quando BILLING_PROVIDER=asaas — webhook rejeita tudo (401) se vazio.
# Deve casar com o token configurado no painel Asaas (header "asaas-access-token").
ASAAS_WEBHOOK_TOKEN=
FRONTEND_URL=http://localhost:8080

# Use stub até ter chave real do Asaas (sandbox: começa com $aact_...)
# BILLING_PROVIDER=stub
TRIAL_DAYS=7

# Sentry (opcional — vazio desliga)
# Projeto: korus-one-api na org ef-mv
# SENTRY_DSN=https://0aee2deeb4a2d48684949718be48fcff@o231577.ingest.us.sentry.io/4511731180240896
SENTRY_DSN=
# development | staging | production (vazio = development se DEBUG=true, senão production)
SENTRY_ENVIRONMENT=
# Fração de traces (vazio = 0 em debug, 0.1 em produção)
# SENTRY_TRACES_SAMPLE_RATE=0.1
# Release (CI): git sha ou tag
# SENTRY_RELEASE=

# ---------------------------------------------------------------------------
# Railway (produção) — variáveis no painel / `railway variables`
# Spec: docs/superpowers/specs/2026-07-15-railway-deploy-design.md
# ---------------------------------------------------------------------------
# DEBUG=false
# PORT=                    # injetado pelo Railway
# DATABASE_URL=            # referência ao plugin Postgres (normalizado para +asyncpg)
# REDIS_URL=               # referência ao plugin Redis
# JWT_SECRET=              # >=32 chars aleatórios
# CORS_ORIGINS=https://SEU-WORKER.workers.dev
# FRONTEND_URL=https://SEU-WORKER.workers.dev
# APP_PUBLIC_URL=https://SUA-API.up.railway.app
#
# AWS S3 (não MinIO):
# S3_ENDPOINT=             # vazio / omitir
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=
# S3_REGION=us-east-1
#
# Com DEBUG=false + WHATSAPP_PROVIDER=evolution (obrigatórias):
# EVOLUTION_API_BASE_URL=
# EVOLUTION_GLOBAL_API_KEY=
# EVOLUTION_WEBHOOK_SECRET=
# WHATSAPP_CREDENTIAL_ENCRYPTION_KEY=
# WHATSAPP_USE_ARQ_DISPATCH=true   # se o serviço worker estiver up
#
# OPENCODE_API_KEY=
# EMAIL_SENDING_ENABLED=true
# RESEND_API_KEY=
# EMAIL_FROM=
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
#
# Ponte Cloudflare (repo web): API_ORIGIN = origin desta API sem path
#   ex. https://SUA-API.up.railway.app
#
# Serviço worker (mesma imagem): start = arq worker.WorkerSettings
