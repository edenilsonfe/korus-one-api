# App
APP_NAME=Korus One API
DEBUG=true
API_V1_PREFIX=/api/v1
# Origens permitidas em produção (DEBUG=false). Em dev, localhost:* é aceito via regex.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:4173,http://127.0.0.1:3000,http://127.0.0.1:5173,http://127.0.0.1:4173

# Database
DATABASE_URL=postgresql+asyncpg://korus:korus@localhost:5433/korus_one

# JWT
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis (arq worker)
REDIS_URL=redis://localhost:6380

# Transactional email (Resend)
RESEND_API_KEY=
EMAIL_FROM=Korus One <noreply@seudominio.com>
EMAIL_SENDING_ENABLED=false
PASSWORD_TOKEN_EXPIRE_MINUTES=60
PASSWORD_RESET_COOLDOWN_SECONDS=60

# MinIO / S3
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=korus-attachments
S3_REGION=us-east-1

# OpenCode Zen (LLM — API compatível com OpenAI)
# Chave em https://opencode.ai/auth
OPENCODE_API_KEY=
OPENCODE_BASE_URL=https://opencode.ai/zen/v1
OPENCODE_MODEL=deepseek-v4-flash

# WhatsApp / Evolution API
WHATSAPP_PROVIDER=evolution
WHATSAPP_CREDENTIAL_ENCRYPTION_KEY=
APP_PUBLIC_URL=
EVOLUTION_API_BASE_URL=http://localhost:8080
EVOLUTION_GLOBAL_API_KEY=
EVOLUTION_WEBHOOK_SECRET=
CLINIC_TIMEZONE=America/Sao_Paulo
WHATSAPP_SCHEDULER_INTERVAL_SECONDS=900
WHATSAPP_REMINDER_WINDOW_HOURS=24
WHATSAPP_REMINDER_TOLERANCE_MINUTES=15

# Billing / Asaas
BILLING_PROVIDER=stub
ASAAS_API_KEY=
ASAAS_API_BASE_URL=https://sandbox.asaas.com/api/v3
ASAAS_WEBHOOK_TOKEN=
FRONTEND_URL=http://localhost:8080

# Use stub até ter chave real do Asaas (sandbox: começa com $aact_...)
# BILLING_PROVIDER=stub
TRIAL_DAYS=7
